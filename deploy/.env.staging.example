# ============================================================
# JAVOS - Arquivo de Configuração (Staging / Homologação)
# ============================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para '.env.staging':
#        cp .env.staging.example .env.staging
#   2. Edite os valores marcados com CHANGE_ME
#   3. Gere o certificado SSL: ./init-ssl.sh
#   4. Inicie: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# DIFERENÇAS EM RELAÇÃO À PRODUÇÃO:
#   - SPRING_PROFILES_ACTIVE=staging (logs mais verbosos)
#   - Banco de dados separado (javos-staging.db ou schema staging_javos)
#   - Grafana na porta 3001 para não conflitar com prod
#   - Certificado SSL autoassinado (padrão)
#
# ============================================================

# ------------------------------------------------------------
# PORTAS (ajuste para evitar conflito com outros ambientes)
# ------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# ------------------------------------------------------------
# DOMÍNIO DE STAGING
# ------------------------------------------------------------
# Exemplo: DOMAIN=staging.app.meusite.com.br
DOMAIN=staging.localhost

# ------------------------------------------------------------
# SEGURANÇA JWT
# ------------------------------------------------------------
# IMPORTANTE: Use uma chave diferente da produção!
# Gerar: openssl rand -hex 64
# O valor abaixo é apenas um placeholder — NUNCA use em produção!
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_VALUE_staging

# Tempo de expiração do refresh token (em dias)
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ------------------------------------------------------------
# PERFIL SPRING
# ------------------------------------------------------------
# "staging" usa logs mais verbosos que "prod"
SPRING_PROFILES_ACTIVE=staging

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# Restrinja ao domínio de staging. Nunca use * em staging/prod.
# Exemplo: CORS_ALLOWED_ORIGINS=https://staging.app.meusite.com.br
CORS_ALLOWED_ORIGINS=https://staging.localhost

# ------------------------------------------------------------
# LET'S ENCRYPT (opcional em staging)
# ------------------------------------------------------------
CERTBOT_EMAIL=seu-email@exemplo.com

# ============================================================
# BANCO DE DADOS — Escolha UMA das opções abaixo:
# ============================================================

# ------------------------------------------------------------
# OPÇÃO 1: SQLite (banco isolado de staging)
# ------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:sqlite:./data/javos-staging.db
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.sqlite.JDBC
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.community.dialect.SQLiteDialect

# ------------------------------------------------------------
# OPÇÃO 2: MySQL (schema separado para staging)
# ------------------------------------------------------------
# Para usar MySQL:
#   1. Comente as 5 linhas da OPÇÃO 1 acima
#   2. Descomente as linhas abaixo
#   3. Crie o schema: CREATE DATABASE staging_javos ...
#
# SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/staging_javos?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
# SPRING_DATASOURCE_USERNAME=javos_staging_user
# SPRING_DATASOURCE_PASSWORD=CHANGE_ME_staging_db_password
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
# MYSQL_ROOT_PASSWORD=CHANGE_ME_staging_root_password
# MYSQL_PASSWORD=CHANGE_ME_staging_db_password

# ============================================================
# DOCKER IMAGE (opcional — para usar imagem pré-construída do CI)
# ============================================================
# Se não definido, o compose faz build local.
# Exemplo: DOCKER_IMAGE=ghcr.io/cesarsuchoj/javos:staging
# DOCKER_IMAGE=ghcr.io/cesarsuchoj/javos:staging
# DOCKER_IMAGE_NGINX=ghcr.io/cesarsuchoj/javos-nginx:staging

# ============================================================
# MONITORAMENTO - Prometheus + Grafana
# ============================================================
# Porta do Grafana (3001 para não conflitar com prod na porta 3000)
GRAFANA_PORT=3001

# Usuário administrador do Grafana
GRAFANA_ADMIN_USER=admin

# Senha do administrador do Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_staging_grafana_password

# URL pública do Grafana de staging
GRAFANA_ROOT_URL=https://staging.localhost:3001

# Retenção de dados do Prometheus (7 dias em staging)
PROMETHEUS_RETENTION=7d
