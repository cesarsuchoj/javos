# ============================================================
# JAVOS - Arquivo de Configuração
# ============================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para '.env' na mesma pasta:
#        Linux/Mac: cp .env.example .env
#        Windows:   copy .env.example .env
#   2. Edite o arquivo '.env' conforme necessário
#   3. Execute './start.sh' (Linux/Mac) ou 'start.bat' (Windows)
#
# ============================================================

# ------------------------------------------------------------
# PORTA DA APLICAÇÃO
# ------------------------------------------------------------
# Porta em que a aplicação ficará disponível.
# Acesse em: http://localhost:APP_PORT
APP_PORT=8080

# ------------------------------------------------------------
# SEGURANÇA JWT
# ------------------------------------------------------------
# IMPORTANTE: Altere este valor para uma string aleatória longa
# antes de usar em produção!
JWT_SECRET=javos-change-this-secret-in-production-to-a-long-random-string

# ============================================================
# BANCO DE DADOS - Escolha UMA das opções abaixo:
# ============================================================

# ------------------------------------------------------------
# OPÇÃO 1: SQLite (PADRÃO - recomendado para uso local)
# ------------------------------------------------------------
# Não requer instalação adicional. Os dados ficam em um arquivo
# local dentro do container Docker.
#
SPRING_DATASOURCE_URL=jdbc:sqlite:./data/javos.db
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.sqlite.JDBC
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.community.dialect.SQLiteDialect

# ------------------------------------------------------------
# OPÇÃO 2: MySQL (para uso em rede ou múltiplos usuários)
# ------------------------------------------------------------
# Para usar MySQL:
#   1. Comente as 5 linhas da OPÇÃO 1 acima (adicione # no início)
#   2. Descomente as linhas abaixo (remova o # do início)
#   3. Execute './stop.sh' e depois './start.sh' para reiniciar
#
# SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/javos?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
# SPRING_DATASOURCE_USERNAME=javos_user
# SPRING_DATASOURCE_PASSWORD=javos_password
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_PASSWORD=javos_password
